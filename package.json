{
  "name": "official-merch-frontend",
  "private": true,
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.22.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.45.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/react-router-dom": "^5.3.3",
    "@vitejs/plugin-react": "^5.1.3",
    "autoprefixer": "10.4.20",
    "dotenv": "^17.2.4",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.4.10",
    "vite": "^5.0.0"
  },
  "scripts": {
    "test:guard": "powershell -ExecutionPolicy Bypass -File .\\scripts\\check_no_hardcoded_test_creds.ps1",
    "ui:install": "npx playwright install --with-deps",
    "ui:test": "npx playwright test",
    "ui:test:stress": "npx playwright test --workers=100%",
    "ui:smoke:full": "npx playwright test --config=playwright.config.ts --reporter=line",
    "ui:smoke": "npx playwright test tests/smoke",
    "ui:admin": "npx playwright test tests/admin",
    "ui:forms": "npx playwright test tests/forms",
    "ui:onboarding": "npx playwright test tests/onboarding",
    "ui:commerce": "npx playwright test tests/commerce tests/auth",
    "ui:regression": "npx playwright test tests/admin tests/forms tests/commerce tests/onboarding tests/auth",
    "ui:smoke:verbose": "npx playwright test tests/smoke/admin.smoke.spec.ts tests/smoke/artist.smoke.spec.ts tests/smoke/buyer.smoke.spec.ts tests/smoke/label.smoke.spec.ts --config=playwright.config.ts --reporter=list --workers=1",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview"
  }
}
