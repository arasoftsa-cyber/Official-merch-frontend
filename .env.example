# Frontend-only browser-safe env keys.
# Set VITE_API_BASE_URL when the API is hosted on a different origin.
# Leave it unset to use same-origin in production or localhost in dev.
VITE_API_BASE_URL=https://api.officialmerch.tech
VITE_PUBLIC_APP_URL=https://officialmerch.tech
VITE_OIDC_CALLBACK_PATH=/auth/oidc/callback
