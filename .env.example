# Frontend env contract aligned to backend `BACKEND_BASE_URL`.
# Source of truth: `../Official-merch-backend/docs/env_contract.md`.
# Canonical API base key (recommended for all modes):
VITE_BACKEND_BASE_URL=https://api.officialmerch.tech

# Optional mode-specific compatibility keys (legacy support):
# VITE_API_BASE_PROD=https://api.officialmerch.tech
# VITE_API_BASE_DEV=http://localhost:3000
# VITE_PROD_API_BASE_URL=https://api.officialmerch.tech
# VITE_API_BASE_URL=https://api.officialmerch.tech

# Local development typical value:
# VITE_BACKEND_BASE_URL=http://localhost:3000

# CI lanes:
# - local UI lane (`ui:test:local` / `ci:local`): localhost API/UI origins only
# - prod-config lane (`ui:test:prod-config` / `ci:prod-config`): non-localhost production origins
VITE_PUBLIC_APP_URL=https://officialmerch.tech
VITE_OIDC_CALLBACK_PATH=/auth/oidc/callback
