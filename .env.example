# Production example values. For local development, use `.env.ui.local`.
# Preferred env contract:
# - production build: VITE_API_BASE_PROD
# - non-production build: VITE_API_BASE_DEV
# CI lanes:
# - local UI lane (`ui:test:local` / `ci:local`): use localhost values
# - prod-config lane (`ui:test:prod-config` / `ci:prod-config`): set production URL contract values
VITE_API_BASE_DEV=http://localhost:3000
VITE_API_BASE_PROD=https://api.officialmerch.tech
# Optional compatibility fallback (used only if mode-specific key is missing):
VITE_API_BASE_URL=https://api.officialmerch.tech
VITE_PUBLIC_APP_URL=https://officialmerch.tech
VITE_OIDC_CALLBACK_PATH=/auth/oidc/callback
